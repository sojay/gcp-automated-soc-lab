server:
  http_listen_port: {{ promtail_http_listen_port | default(9080) }}
  grpc_listen_port: 0

positions:
  filename: {{ promtail_positions_file | default('/var/lib/promtail/positions.yaml') }}

clients:
  - url: http://{{ logging_internal_ip | default('10.10.3.2') }}:{{ loki_listen_port | default(3100) }}/loki/api/v1/push

scrape_configs:
  - job_name: cowrie
    static_configs:
      - targets:
          - localhost
        labels:
          job: cowrie
          host: cowrie-1
          __path__: {{ promtail_container_log_glob | default('/var/log/cowrie/cowrie.json*') }}
    pipeline_stages:
      - json:
          expressions:
            eventid: eventid
            src_ip: src_ip
      - labels:
          eventid:
{% if geoip_enabled | default(false) | bool %}
      - geoip:
          db: {{ promtail_geoip_db_container_path | default('/etc/promtail/GeoLite2-City.mmdb') }}
          source: src_ip
          db_type: city
      - labels:
          geoip_country_name:
          geoip_country_code:
{% endif %}
